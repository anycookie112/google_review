# -----------------------------------------------------------------------------
# Auth + Postgres
# -----------------------------------------------------------------------------
# For local setup:
#   1. cp .env.example .env
#   2. docker compose up -d db
#   3. npm install && npm run dev
#
# The app auto-creates its auth table on first request and seeds the initial
# admin user from ADMIN_EMAIL / ADMIN_PASSWORD if that email does not exist yet.

POSTGRES_DB=reviews_monitor
POSTGRES_USER=reviews_monitor
POSTGRES_PASSWORD=reviews_monitor
POSTGRES_PORT=5432
DATABASE_URL=postgresql://reviews_monitor:reviews_monitor@127.0.0.1:5432/reviews_monitor
# Set to "require" for hosted Postgres providers that enforce SSL.
DATABASE_SSL=

# Must be at least 32 characters long.
AUTH_SECRET=replace-me-with-a-long-random-secret-value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
ADMIN_NAME=Initial Admin

# -----------------------------------------------------------------------------
# Google APIs
# -----------------------------------------------------------------------------
# Optional fallback: Google Maps Platform API key with the "Places API (New)" enabled.
# Server-side only — never expose this to the browser.
# Leave blank if you want Business Profile Mode only, or leave unset to fall back to Mock Mode.
GOOGLE_MAPS_API_KEY=

# Google OAuth client for Business Profile API access.
# Local dev example:
#   GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/api/google/oauth/callback
# Funnel/staging/prod must use the exact public HTTPS callback you register in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/api/google/oauth/callback

# Optional secret for cron / scheduler calls to POST /api/internal/sync
SYNC_CRON_SECRET=

# -----------------------------------------------------------------------------
# Tunneling
# -----------------------------------------------------------------------------
# ngrok authtoken — used by `npm run tunnel` / `npm run dev:tunnel` to expose
# the local dev server (port 3000) to the public internet for demos.
# Get a free token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
