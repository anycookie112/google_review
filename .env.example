# Google Maps Platform API key with the "Places API (New)" enabled.
# Server-side only — never expose this to the browser.
# Leave blank or unset to run the app in Mock Mode with seeded demo data.
GOOGLE_MAPS_API_KEY=

# ngrok authtoken — used by `npm run tunnel` / `npm run dev:tunnel` to expose
# the local dev server (port 3000) to the public internet for demos.
# Get a free token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
